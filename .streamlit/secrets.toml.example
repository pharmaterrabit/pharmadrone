# Streamlit Community Cloud secrets template.
# On share.streamlit.io: app -> Settings -> Secrets -> paste the block below
# (with your real values) into the box. It is stored by Streamlit, NOT in git.
# Locally, you may instead copy this to .streamlit/secrets.toml for testing —
# that file is already in .gitignore.

APP_PASSWORD = "choose-a-password"
# Use distinct values. The server routes each credential to its assigned role.
PLATFORM_ADMIN_PASSWORD = "choose-a-different-platform-admin-password"
WORKSPACE_ADMIN_PASSWORD = "choose-a-different-workspace-admin-password"
# Set this after Platform Administration creates the production organisation.
WORKSPACE_ADMIN_ORGANISATION_ID = "org-replace-with-created-id"

LLM_PROVIDER = "openrouter"
LLM_MODEL = "meta-llama/llama-3.3-70b-instruct:free"
OPENROUTER_API_KEY = ""
GROQ_API_KEY = ""
OPENAI_API_KEY = ""
GEMINI_API_KEY = ""

TAVILY_API_KEY = ""
CONTACT_EMAIL = ""

MAX_REPORTS_PER_RUN = "5"
ALLOW_SCALE_RUNS = "false"

# Durable production persistence. Paste the managed PostgreSQL URL here.
DATABASE_URL = ""
APP_ENV = "production"
# Local development only; do not use this fallback in production:
# DATABASE_BACKEND = "sqlite"
# SQLITE_PATH = "pharmadrone.db"

# Checkpoint 6C.1 scheduler status is read from PostgreSQL. Scheduled jobs use
# GitHub Actions Secrets, not this Streamlit file.
# CHECKPOINT6C1_AUTOMATED_TEST_RESULT = "75 passed; 1 optional PostgreSQL test skipped"
# POSTGRES_SCHEDULER_PERSISTENCE_TEST_RESULT = "pending"
# SCHEDULED_RUN_PERSISTENCE_TEST_RESULT = "pending"
